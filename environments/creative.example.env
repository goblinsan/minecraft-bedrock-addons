# Creative server environment configuration (multi-server example)
# Copy this file to creative.env and fill in your values.
# creative.env is git-ignored and should never be committed.
#
# Used with: docker/examples/docker-compose.multi.yml (bedrock-creative service)

# Name of the Docker container running this Bedrock server
CONTAINER_NAME=bedrock-creative

# Absolute path on the Docker host where the world folder is mounted
HOST_WORLD_PATH=/opt/bedrock/creative/worlds/CreativeWorld

# Name of the world inside the server (must match a folder in worlds/)
WORLD_NAME=CreativeWorld

# Path inside the container where behavior packs should be installed
BEHAVIOR_PACK_DEST=/data/behavior_packs

# Path inside the container where resource packs should be installed
RESOURCE_PACK_DEST=/data/resource_packs

# Space-separated list of pack names that are enabled in this environment.
# deploy-all.sh uses this list to restrict which packs get deployed.
# Leave empty or omit to deploy all packs found under packs/.
ENABLED_PACKS=""
